# Server
PORT=5118
NODE_ENV=development

# JWT
JWT_SECRET=
JWT_OTP_EXPIRY_SECONDS=300
JWT_AUTH_EXPIRY_SECONDS=600

# Database
DB_FILE_NAME=./data/portal.db

# MSG91 (deprecated — using Resend email OTP instead)
MSG91_AUTH_KEY=
MSG91_TEMPLATE_ID=
MSG91_SENDER_ID=IPNOTC

# Resend (Email OTP)
RESEND_API_KEY=
RESEND_FROM=IPNOTEC <otp@ipnotec.in>

# Omada Controller (self-hosted v2 API — on same VM, use localhost)
OMADA_URL=https://localhost:8043
OMADA_USER=
OMADA_PASS=
OMADA_SITE_ID=

# Admin
ADMIN_USERNAME=admin
ADMIN_PASSWORD=
ADMIN_JWT_SECRET=
